<div class="row g-4">
  <div class="col-lg-5"><div class="panel-card"><h3 class="mb-3">Yangi toifa</h3><form method="post" action="/admin/categories" class="row g-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><div class="col-md-8"><label>Nomi</label><input class="form-control" type="text" name="name" required /></div><div class="col-md-4"><label>Narx / kg</label><input class="form-control" type="number" name="pricePerKg" required /></div><div class="col-12"><label>Tavsif</label><textarea class="form-control" rows="3" name="description"></textarea></div><div class="col-md-6"><label>Belgi</label><input class="form-control" type="text" name="icon" value="ri-recycle-line" /></div><div class="col-md-6"><label>Tartib</label><input class="form-control" type="number" name="sortOrder" value="0" /></div><div class="col-12 form-check ms-1"><input class="form-check-input" type="checkbox" id="catActive" name="isActive" checked /><label class="form-check-label" for="catActive">Faol</label></div><div class="col-12"><button class="btn btn-gradient" type="submit">Saqlash</button></div></form></div></div>
  <div class="col-lg-7"><div class="panel-card table-responsive"><table class="table align-middle"><thead><tr><th>Toifa</th><th>Narx</th><th>Belgi</th><th>Holat</th></tr></thead><tbody><% items.forEach((item) => { %><tr><td><strong><%= item.name %></strong><div class="text-muted"><%= item.description %></div></td><td><%= helpers.formatCurrency(item.pricePerKg) %></td><td><i class="<%= item.icon %>"></i></td><td><span class="<%= item.isActive ? 'badge-soft-success' : 'badge-soft-muted' %>"><%= item.isActive ? 'Faol' : 'Nofaol' %></span></td></tr><% }) %></tbody></table></div></div>
</div>
