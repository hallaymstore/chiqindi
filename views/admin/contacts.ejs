<div class="panel-card table-responsive"><table class="table align-middle"><thead><tr><th>Ism</th><th>Email</th><th>Telefon</th><th>Mavzu</th><th>Status</th><th>Sana</th></tr></thead><tbody><% items.forEach((item) => { %><tr><td><strong><%= item.name %></strong><div class="text-muted"><%= item.message %></div></td><td><%= item.email %></td><td><%= item.phone || '—' %></td><td><%= item.subject || '—' %></td><td><span class="badge-soft-primary"><%= item.status %></span></td><td><%= helpers.formatDate(item.createdAt) %></td></tr><% }) %></tbody></table></div>
