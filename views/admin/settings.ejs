<div class="panel-card"><form method="post" action="/admin/settings" class="row g-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><div class="col-md-6"><label>Platforma nomi</label><input class="form-control" type="text" name="siteName" value="<%= settings?.siteName || '' %>" /></div><div class="col-md-6"><label>Shior</label><input class="form-control" type="text" name="tagline" value="<%= settings?.tagline || '' %>" /></div><div class="col-md-6"><label>Yordam email</label><input class="form-control" type="email" name="supportEmail" value="<%= settings?.supportEmail || '' %>" /></div><div class="col-md-6"><label>Aloqa telefoni</label><input class="form-control" type="text" name="supportPhone" value="<%= settings?.supportPhone || '' %>" /></div><div class="col-12"><label>Manzil</label><input class="form-control" type="text" name="address" value="<%= settings?.address || '' %>" /></div><div class="col-md-6"><label>SEO sarlavha</label><input class="form-control" type="text" name="seoTitle" value="<%= settings?.seoDefaults?.title || '' %>" /></div><div class="col-md-6"><label>SEO tavsifi</label><input class="form-control" type="text" name="seoDescription" value="<%= settings?.seoDefaults?.description || '' %>" /></div><div class="col-md-4"><label>Telegram</label><input class="form-control" type="text" name="telegram" value="<%= settings?.socialLinks?.telegram || '' %>" /></div><div class="col-md-4"><label>Instagram</label><input class="form-control" type="text" name="instagram" value="<%= settings?.socialLinks?.instagram || '' %>" /></div><div class="col-md-4"><label>LinkedIn</label><input class="form-control" type="text" name="linkedin" value="<%= settings?.socialLinks?.linkedin || '' %>" /></div><div class="col-md-6"><label>Hero sarlavha</label><input class="form-control" type="text" name="heroTitle" value="<%= settings?.heroTitle || '' %>" /></div><div class="col-md-6"><label>Hero subtitle</label><input class="form-control" type="text" name="heroSubtitle" value="<%= settings?.heroSubtitle || '' %>" /></div><div class="col-md-6"><label>Narx rejimi</label><select class="form-select" name="wastePricingMode"><option value="dynamic" <%= settings?.wastePricingMode === 'dynamic' ? 'selected' : '' %>>Dinamik</option><option value="fixed" <%= settings?.wastePricingMode === 'fixed' ? 'selected' : '' %>>Qat'iy</option></select></div><div class="col-12"><label>Tavsif</label><textarea class="form-control" rows="4" name="description"><%= settings?.description || '' %></textarea></div><div class="col-12"><button class="btn btn-gradient" type="submit">Sozlamalarni saqlash</button></div></form></div>

