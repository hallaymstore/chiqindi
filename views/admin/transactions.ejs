<div class="panel-card table-responsive"><table class="table align-middle"><thead><tr><th>ID</th><th>Turi</th><th>Vazn</th><th>Summa</th><th>Status</th><th>Sana</th></tr></thead><tbody><% items.forEach((item) => { %><tr><td><strong><%= item.transactionId || item._id %></strong></td><td><%= item.type %></td><td><%= helpers.formatKg(item.weight) %></td><td><%= helpers.formatCurrency(item.amount) %></td><td><span class="badge-soft-primary"><%= item.status %></span></td><td><%= helpers.formatDate(item.createdAt) %></td></tr><% }) %></tbody></table></div>
