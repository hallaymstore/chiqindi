<div class="row g-4">
  <div class="col-lg-5"><div class="panel-card"><h3 class="mb-3">Yangi maqola</h3><form method="post" action="/admin/blog" enctype="multipart/form-data" class="row g-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><div class="col-12"><label>Sarlavha</label><input class="form-control" type="text" name="title" required /></div><div class="col-12"><label>Qisqa izoh</label><textarea class="form-control" rows="3" name="excerpt"></textarea></div><div class="col-12"><label>Maqola matni</label><textarea class="form-control" rows="8" name="content" required></textarea></div><div class="col-md-6"><label>Kategoriya teglar</label><input class="form-control" type="text" name="categories" placeholder="ekologiya, qayta ishlash" /></div><div class="col-md-6"><label>Taglar</label><input class="form-control" type="text" name="tags" placeholder="plastik, pickup" /></div><div class="col-md-6"><label>SEO sarlavha</label><input class="form-control" type="text" name="seoTitle" /></div><div class="col-md-6"><label>SEO tavsifi</label><input class="form-control" type="text" name="seoDescription" /></div><div class="col-md-6"><label>Status</label><select class="form-select" name="status"><option value="published">Nashrda</option><option value="draft">Qoralama</option></select></div><div class="col-md-6"><label>Asosiy rasm</label><input class="form-control" type="file" name="featuredImage" accept="image/*" /></div><div class="col-12 form-check ms-1"><input class="form-check-input" type="checkbox" id="featuredPost" name="featured" /><label class="form-check-label" for="featuredPost">Asosiy maqola</label></div><div class="col-12"><button class="btn btn-gradient" type="submit">Maqolani saqlash</button></div></form></div></div>
  <div class="col-lg-7"><div class="panel-card table-responsive"><table class="table align-middle"><thead><tr><th>Maqola</th><th>Muallif</th><th>Status</th><th>Sana</th></tr></thead><tbody><% items.forEach((item) => { %><tr><td><strong><%= item.title %></strong><div class="text-muted"><%= item.excerpt %></div></td><td><%= item.author?.name || 'Admin' %></td><td><span class="badge-soft-primary"><%= item.status %></span></td><td><%= helpers.formatDate(item.createdAt) %></td></tr><% }) %></tbody></table></div></div>
</div>

