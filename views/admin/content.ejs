<div class="panel-card"><form method="post" action="/admin/settings" class="row g-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><input type="hidden" name="redirectTo" value="/admin/content" /><div class="col-md-6"><label>Hero sarlavha</label><input class="form-control" type="text" name="heroTitle" value="<%= settings?.heroTitle || '' %>" /></div><div class="col-md-6"><label>Hero subtitle</label><input class="form-control" type="text" name="heroSubtitle" value="<%= settings?.heroSubtitle || '' %>" /></div><div class="col-12"><label>Tagline</label><input class="form-control" type="text" name="tagline" value="<%= settings?.tagline || '' %>" /></div><div class="col-12"><label>Tavsif</label><textarea class="form-control" rows="4" name="description"><%= settings?.description || '' %></textarea></div><div class="col-12"><button class="btn btn-gradient" type="submit">Kontentni saqlash</button></div></form></div>
