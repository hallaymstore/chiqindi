<section class="section-space auth-shell">
  <div class="container">
    <div class="row g-4 align-items-center">
      <div class="col-lg-5">
        <div class="auth-aside">
          <span class="eyebrow"><i class="ri-login-circle-line"></i> Tizimga kirish</span>
          <h2 class="mt-3">Topshiriqlar, to'lovlar va jarayonlarni bir joydan boshqaring</h2>
          <ul>
            <li class="mini-kpi"><strong>Aniq holatlar</strong><span>So'rov va to'lov oqimi shaffof ko'rinadi.</span></li>
            <li class="mini-kpi"><strong>Rolga mos boshqaruv</strong><span>Har bir foydalanuvchi uchun alohida ish muhiti mavjud.</span></li>
            <li class="mini-kpi"><strong>Ekologik foyda</strong><span>Har bir topshiruv qayta ishlashga real hissa qo'shadi.</span></li>
          </ul>
        </div>
      </div>
      <div class="col-lg-7">
        <div class="auth-card">
          <h2>Kirish</h2>
          <p class="text-muted">Hisobingizga kiring va jarayonni davom ettiring.</p>
          <form method="post" action="/login" class="row g-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12">
              <label>Email</label>
              <input class="form-control" type="email" name="email" required />
            </div>
            <div class="col-12">
              <label>Parol</label>
              <input class="form-control" type="password" name="password" required />
            </div>
            <div class="col-12 d-flex justify-content-between align-items-center">
              <a href="/forgot-password">Parolni unutdingizmi?</a>
              <button class="btn btn-gradient" type="submit">Kirish</button>
            </div>
          </form>
          <p class="mt-4 mb-0">Hisobingiz yo'qmi? <a href="/register">Ro'yxatdan o'ting</a></p>
        </div>
      </div>
    </div>
  </div>
</section>