<section class="section-space auth-shell">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6">
        <div class="auth-card">
          <span class="eyebrow"><i class="ri-lock-password-line"></i> Parolni tiklash</span>
          <h2 class="mt-3">Parol tiklash so'rovini yuboring</h2>
          <p>So'rovingiz qabul qilingach, siz bilan bog'lanib parolni tiklash bo'yicha yordam ko'rsatiladi.</p>
          <form method="post" action="/forgot-password" class="row g-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12">
              <label>Email</label>
              <input class="form-control" type="email" name="email" required />
            </div>
            <div class="col-12">
              <button class="btn btn-gradient" type="submit">So'rov yuborish</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>