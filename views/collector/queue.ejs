<div class="list-stack">
  <% items.forEach((item) => { %>
    <div class="panel-card">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
          <h3 class="mb-1"><%= item.user?.name %> - <%= item.category?.name %></h3>
          <p class="mb-0"><%= item.address %></p>
        </div>
        <span class="<%= helpers.statusBadgeClass(item.status) %>"><%= helpers.formatStatus(item.status) %></span>
      </div>
      <form method="post" action="/collector/pickups/<%= item._id %>/status" enctype="multipart/form-data" class="row g-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-md-4">
          <label>Status</label>
          <select class="form-select" name="status">
            <option value="assigned">Biriktirildi</option>
            <option value="on_the_way">Yo'lda</option>
            <option value="collected">Yig'ib olindi</option>
            <option value="completed">Yakunlandi</option>
            <option value="cancelled">Bekor qilindi</option>
          </select>
        </div>
        <div class="col-md-4">
          <label>Haqiqiy vazn</label>
          <input class="form-control" type="number" step="0.1" name="actualWeight" value="<%= item.actualWeight || item.estimatedWeight %>" />
        </div>
        <div class="col-md-4">
          <label>Tasdiq rasmi</label>
          <input class="form-control" type="file" name="proofPhotos" accept="image/*" multiple />
        </div>
        <div class="col-12">
          <label>Izoh</label>
          <textarea class="form-control" rows="3" name="note"></textarea>
        </div>
        <div class="col-12">
          <button class="btn btn-gradient" type="submit">Statusni yangilash</button>
        </div>
      </form>
    </div>
  <% }) %>

  <% if (!items.length) { %>
    <div class="empty-state">Faol topshiriq topilmadi.</div>
  <% } %>
</div>
