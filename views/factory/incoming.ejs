<div class="list-stack">
  <% items.forEach((item) => { %>
    <div class="panel-card">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
          <h3 class="mb-1"><%= item.user?.name %> · <%= item.category?.name %></h3>
          <p class="mb-0"><%= item.collectionPoint?.name || 'To‘g‘ridan-to‘g‘ri' %></p>
        </div>
        <span class="<%= helpers.statusBadgeClass(item.status) %>"><%= helpers.formatStatus(item.status) %></span>
      </div>
      <form method="post" action="/factory/pickups/<%= item._id %>/decision" class="row g-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-md-4"><label>Qaror</label><select class="form-select" name="decision"><option value="accept">Qabul qilish</option><option value="reject">Rad etish</option></select></div>
        <div class="col-md-4"><label>Haqiqiy vazn</label><input class="form-control" type="number" step="0.1" name="actualWeight" value="<%= item.actualWeight || item.estimatedWeight %>" /></div>
        <div class="col-md-4"><label>Izoh</label><input class="form-control" type="text" name="note" /></div>
        <div class="col-12"><button class="btn btn-gradient" type="submit">Qarorni saqlash</button></div>
      </form>
    </div>
  <% }) %>
  <% if (!items.length) { %><div class="empty-state">Kelib tushayotgan partiyalar yo‘q.</div><% } %>
</div>
