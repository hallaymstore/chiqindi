<div class="panel-card table-responsive"><table class="table align-middle"><thead><tr><th>Sana</th><th>Actor</th><th>Action</th><th>Entity</th><th>Izoh</th></tr></thead><tbody><% items.forEach((item) => { %><tr><td><%= helpers.formatDateTime(item.createdAt) %></td><td><%= item.actorName || item.actor?.name || 'System' %></td><td><%= item.action %></td><td><%= item.entityType %></td><td><%= item.description || '—' %></td></tr><% }) %></tbody></table></div>
