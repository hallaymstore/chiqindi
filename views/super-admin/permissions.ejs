<div class="list-stack">
  <% items.forEach((item) => { %>
    <div class="panel-card">
      <h3><%= item.label %></h3>
      <p><%= item.description %></p>
      <form method="post" action="/super-admin/permissions/<%= item._id %>" class="row g-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-12"><label>Ruxsatlar (vergul bilan)</label><textarea class="form-control" rows="3" name="permissions"><%= item.permissions.join(', ') %></textarea></div>
        <div class="col-12"><button class="btn btn-gradient" type="submit">Saqlash</button></div>
      </form>
    </div>
  <% }) %>
</div>
