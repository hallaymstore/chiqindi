<div class="row g-4">
  <div class="col-lg-5"><div class="panel-card panel-dark"><h3 class="mb-3">Platforma komissiyasi</h3><form method="post" action="/super-admin/commissions" class="row g-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><div class="col-12"><label>Komissiya foizi</label><input class="form-control" type="number" step="0.1" name="commissionRate" value="<%= settings?.commissionRate || 0 %>" /></div><div class="col-12"><label>Narx rejimi</label><select class="form-select" name="wastePricingMode"><option value="dynamic" <%= settings?.wastePricingMode === 'dynamic' ? 'selected' : '' %>>Dinamik</option><option value="fixed" <%= settings?.wastePricingMode === 'fixed' ? 'selected' : '' %>>Qat'iy</option></select></div><div class="col-12"><button class="btn btn-gradient" type="submit">Yangilash</button></div></form></div></div>
  <div class="col-lg-7"><div class="panel-card table-responsive"><table class="table align-middle"><thead><tr><th>Toifa</th><th>Narx / kg</th></tr></thead><tbody><% categories.forEach((item) => { %><tr><td><strong><%= item.name %></strong></td><td><%= helpers.formatCurrency(item.pricePerKg) %></td></tr><% }) %></tbody></table></div></div>
</div>

