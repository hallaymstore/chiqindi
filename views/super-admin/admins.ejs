<div class="row g-4">
  <div class="col-lg-5"><div class="panel-card"><h3 class="mb-3">Yangi admin</h3><form method="post" action="/super-admin/admins" class="row g-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>" /><div class="col-md-6"><label>Ism</label><input class="form-control" type="text" name="name" required /></div><div class="col-md-6"><label>Telefon</label><input class="form-control" type="text" name="phone" /></div><div class="col-md-6"><label>Email</label><input class="form-control" type="email" name="email" required /></div><div class="col-md-6"><label>Parol</label><input class="form-control" type="password" name="password" required /></div><div class="col-md-6"><label>Rol</label><select class="form-select" name="role"><option value="admin">Admin</option><option value="super_admin">Super admin</option></select></div><div class="col-md-6"><label>Hudud</label><input class="form-control" type="text" name="region" /></div><div class="col-12"><label>Manzil</label><input class="form-control" type="text" name="address" /></div><div class="col-12"><button class="btn btn-gradient" type="submit">Yaratish</button></div></form></div></div>
  <div class="col-lg-7"><div class="panel-card table-responsive"><table class="table align-middle"><thead><tr><th>Admin</th><th>Rol</th><th>Hudud</th><th>Sana</th></tr></thead><tbody><% items.forEach((item) => { %><tr><td><strong><%= item.name %></strong><div class="text-muted"><%= item.email %></div></td><td><span class="badge-soft-primary"><%= helpers.formatRole(item.role) %></span></td><td><%= item.region || '—' %></td><td><%= helpers.formatDate(item.createdAt) %></td></tr><% }) %></tbody></table></div></div>
</div>
