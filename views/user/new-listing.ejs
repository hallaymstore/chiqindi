<div class="row g-4">
  <div class="col-lg-7">
    <div class="panel-card">
      <form method="post" action="/user/listings" enctype="multipart/form-data" class="row g-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-md-8"><label>Sarlavha</label><input class="form-control" type="text" name="title" placeholder="Masalan: PET butilkalar partiyasi" required /></div>
        <div class="col-md-4"><label>Toifa</label><select class="form-select" name="category" required><option value="">Tanlang</option><% categories.forEach((item) => { %><option value="<%= item._id %>"><%= item.name %></option><% }) %></select></div>
        <div class="col-md-6"><label>Taxminiy vazn (kg)</label><input class="form-control" type="number" step="0.1" name="estimatedWeight" required /></div>
        <div class="col-md-6"><label>Olib ketish vaqti</label><input class="form-control" type="datetime-local" name="preferredPickupAt" /></div>
        <div class="col-12"><label>Manzil</label><input class="form-control" type="text" name="address" required /></div>
        <div class="col-md-6"><label>Hudud</label><input class="form-control" type="text" name="region" placeholder="Toshkent" /></div>
        <div class="col-md-6"><label>Rasmlar</label><input class="form-control" type="file" name="images" accept="image/*" multiple /></div>
        <div class="col-12"><label>Izoh</label><textarea class="form-control" rows="4" name="notes" placeholder="Qadoqlash turi, kirish yo'li va boshqa tafsilotlar"></textarea></div>
        <div class="col-md-6"><label>X koordinata</label><input id="listingLng" class="form-control" type="number" step="0.000001" name="longitude" value="69.2401" /></div>
        <div class="col-md-6"><label>Y koordinata</label><input id="listingLat" class="form-control" type="number" step="0.000001" name="latitude" value="41.2995" /></div>
        <div class="col-12 form-check ms-1"><input class="form-check-input" type="checkbox" id="requestedPickup" name="requestedPickup" checked /><label class="form-check-label" for="requestedPickup">Uyga kelib olib ketish kerak</label></div>
        <div class="col-12"><button class="btn btn-gradient" type="submit">So'rovni yuborish</button></div>
      </form>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="panel-card">
      <h3 class="mb-3">Joylashuvni xaritada belgilang</h3>
      <div class="leaflet-map" id="listingMap" data-clickable="true" data-lat="41.2995" data-lng="69.2401" data-lat-input="#listingLat" data-lng-input="#listingLng" data-points='<%- JSON.stringify(points.map((point) => ({ name: point.name, address: point.address, lat: point.location?.coordinates?.[1] || 41.2995, lng: point.location?.coordinates?.[0] || 69.2401 }))) %>'></div>
    </div>
  </div>
</div>