<div class="row g-4">
  <div class="col-lg-7">
    <div class="panel-card">
      <span class="eyebrow"><i class="ri-brain-line"></i> Tezkor saralash</span>
      <h3 class="mt-3">Surat bo'yicha tavsiya</h3>
      <p>Rasmga qarab mos chiqindi turini tez tanlashga yordam beradi. Zarurat bo'lsa, toifani qo'lda ham belgilashingiz mumkin.</p>
      <form method="post" action="/user/ai-aniqlash" enctype="multipart/form-data" class="row g-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-md-6"><label>Rasm yuklash</label><input class="form-control" type="file" name="image" accept="image/*" /></div>
        <div class="col-md-6"><label>Toifani tanlang</label><select class="form-select" name="manualCategory"><option value="">Kerak bo'lsa tanlang</option><% categories.forEach((item) => { %><option value="<%= item._id %>"><%= item.name %></option><% }) %></select></div>
        <div class="col-12"><button class="btn btn-gradient" type="submit">Tavsiya olish</button></div>
      </form>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="panel-card panel-dark h-100">
      <h3>Natija</h3>
      <% if (suggestion) { %>
        <p class="mt-3 mb-2">Tavsiya qilingan toifa</p>
        <div class="kpi-chip mb-3"><strong><%= suggestion.name %></strong><span><%= helpers.formatCurrency(suggestion.pricePerKg) %> / kg</span></div>
        <p><%= suggestion.description %></p>
      <% } else { %>
        <p class="mt-3">Hali tavsiya shakllanmagan. Rasm yuklang yoki toifani tanlang.</p>
      <% } %>
      <% if (uploadedImage) { %><img src="<%= uploadedImage %>" alt="uploaded" class="rounded-4 mt-3" /> <% } %>
    </div>
  </div>
</div>